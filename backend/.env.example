# ── News source ───────────────────────────────────────────────────────────────
# Free tier: https://newsapi.org/register (100 req/day, last 30 days)
NEWS_API_KEY=your_newsapi_key_here

# ── Claude sentiment analysis ─────────────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── LINE Notify ───────────────────────────────────────────────────────────────
# Personal access token: https://notify-bot.line.me/my/
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# ── API 保護金鑰 ──────────────────────────────────────────────────────────────
# 自己隨意設定一串亂碼，Railway 和 vercel.json 填入同一個值
# 本機開發不需要設定（空值 = 不驗證）
API_SECRET_KEY=

# ── FinMind API key (選填) ────────────────────────────────────────────────────
# 有設定時每日請求上限較高，無設定也可免費使用
# https://finmindtrade.com/analysis/#/Sponsor/sponsor
FINMIND_API_KEY=
